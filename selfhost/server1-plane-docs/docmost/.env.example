# --- Docmost config. Copy to .env and fill in. ---
# Public URL (subdomain + https). Caddy terminates SSL.
APP_URL=https://docs.adam.uz

# 32+ char random secret. Generate: openssl rand -hex 32
APP_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Strong DB password (must match nothing external — internal only)
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
