# Copy to .env and fill. .env is gitignored — never commit real values.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
BOT_USERNAME=brodyone_bot

# Human role authz for telegram gates — JSON { "<telegram_user_id>": "<role>" }.
# Roles: po | pm | design | reviewer | devops | marketing | admin (bypasses all).
# Only the gate-owning role may approve that gate (see GATE_ROLE in ingest/roles.mjs).
HERMES_ROLES={"111111":"pm","222222":"reviewer","333333":"devops","999999":"admin"}

# Plane (self-host) API
PLANE_BASE_URL=https://plane.yourdomain.com
PLANE_API_KEY=plane_api_xxx
PLANE_WORKSPACE_SLUG=your-workspace
