# Copy to .env and fill. .env is gitignored â€” never commit real values.

# --- Telegram (ingest + gates) ---
# Bot token from @BotFather. Turn OFF privacy mode so /task works in groups.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
BOT_USERNAME=brodyone_bot
# Chat id hermesd posts its "online" + escalation messages to (your DM or ops group).
HERMES_CHAT_ID=123456789

# --- Human role authz for telegram gates ---
# JSON { "<telegram_user_id>": "<role>" }.
# Roles: po | pm | design | reviewer | devops | marketing | admin (bypasses all).
# Gateâ†’role: roadmapâ†’po Â· planâ†’pm Â· designâ†’design Â· mergeâ†’reviewer Â· prodâ†’devops Â· publishâ†’marketing.
# Get your numeric id from @userinfobot. Only the gate-owning role may approve.
HERMES_ROLES={"111111":"pm","222222":"reviewer","333333":"devops","999999":"admin"}

# --- Claude (reasoning engine, Max subscription auth on the host) ---
# Model alias for `claude -p` role agents. sonnet = cheaper/faster; opus = deepest.
HERMES_MODEL=sonnet

# --- Plane (self-host) â€” HERMES_MODE=real ---
PLANE_BASE_URL=https://plane.yourdomain.com
PLANE_API_KEY=plane_api_xxx
PLANE_WORKSPACE_SLUG=your-workspace
# Project UUID the issues are created in (Plane â†’ project â†’ Settings â†’ copy the id from the URL).
PLANE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Optional (later phases) ---
# GITLAB_URL=https://gitlab.yourdomain.com
# GITLAB_TOKEN=glpat-xxx
# DOCMOST_URL=https://docs.yourdomain.com
# DOCMOST_API_KEY=xxx
